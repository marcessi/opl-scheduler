# ============================================================
# OPLscheduler — Plantilla de variables de entorno
#
# Copia este fichero como .env y ajusta los valores:
#   cp .env.example .env
#
# - Desarrollo local: los valores por defecto de abajo ya
#   funcionan directamente. No cambies nada.
# - Producción: sustituye TODOS los valores marcados con
#   CAMBIA_ESTO antes de desplegar.
# ============================================================

POSTGRES_DB=opl_scheduler
POSTGRES_USER=opl_user
POSTGRES_PASSWORD=dev_password          # CAMBIA_ESTO en producción

DATABASE_URL=postgresql://opl_user:dev_password@db:5432/opl_scheduler        # CAMBIA_ESTO en producción
TEST_DATABASE_URL=postgresql://opl_user:dev_password@db:5432/opl_scheduler_test

# Clave JWT — genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-secret-key-not-for-production   # CAMBIA_ESTO en producción

# CORS — usa '*' solo en desarrollo; en producción pon tu dominio
CORS_ORIGINS=*                          # CAMBIA_ESTO en producción: https://tu-dominio.com

# Contraseña inicial del usuario 'admin' (solo aplica si la BD está vacía)
ADMIN_BOOTSTRAP_PASSWORD=admin          # CAMBIA_ESTO en producción
