# ============================================================
# OPLscheduler — Variables de entorno
#
# Desarrollo local: NO necesitas este archivo. `docker compose up`
# ya trae credenciales de desarrollo hardcodeadas en docker-compose.yml.
#
# Solo necesitas un .env si quieres desplegar fuera de tu máquina.
# En ese caso copia este fichero como .env y rellena los valores.
# ============================================================

# Entorno: development | production
# En producción se activan validaciones estrictas (CORS, JWT, etc.).
ENV=production

# Base de datos PostgreSQL
DATABASE_URL=postgresql://opl_user:CAMBIA_ESTO@db:5432/opl_scheduler
POSTGRES_PASSWORD=CAMBIA_ESTO

# Clave JWT — genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# CORS — orígenes permitidos, separados por coma (SIN '*' en producción)
CORS_ORIGINS=https://tu-dominio.com

# Contraseña inicial del usuario 'admin'. Solo se aplica si la BD está
# vacía (primer arranque). Cámbiala tras el primer login.
ADMIN_BOOTSTRAP_PASSWORD=CAMBIA_ESTO
