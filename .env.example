# ============================================================
# OPLscheduler — Variables de entorno
#
# Desarrollo local: NO necesitas este archivo.
# `docker compose up` usa docker-compose.override.yml con
# credenciales dev hardcodeadas (dev_password).
#
# Producción on-prem: copia este archivo como .env y rellena.
# Producción en Azure App Service: define estos valores como
# App Settings (Configuration → Application settings). NO subas
# el .env al contenedor.
# ============================================================

# ── Entorno ──────────────────────────────────────────────────
# development | production
# En producción activa validaciones estrictas (CORS, JWT, etc.).
ENV=production

# ── Base de datos PostgreSQL ─────────────────────────────────
# Azure: postgresql://<user>:<password>@<server>.postgres.database.azure.com:5432/<db>?sslmode=require
DATABASE_URL=postgresql://opl_user:CAMBIA_ESTO@db:5432/opl_scheduler

# ── JWT — genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# ── CORS — orígenes permitidos (coma-separados, SIN '*' en prod)
# Esta app + la app de operarios
CORS_ORIGINS=https://tu-scheduler.com,https://tu-app-operarios.com

# ── Bootstrap admin ──────────────────────────────────────────
# Contraseña inicial del usuario 'admin'. Solo se aplica si la BD está vacía.
# Cámbiala tras el primer login. NO uses 'admin1234' en producción.
ADMIN_BOOTSTRAP_PASSWORD=CAMBIA_ESTO

# ── PostgreSQL (para docker-compose.yml on-prem, no aplica en Azure) ─
POSTGRES_PASSWORD=CAMBIA_ESTO

# ── Azure App Service (solo si despliegas en Azure) ──────────
# WEBSITES_PORT=8000 indica a App Service que el contenedor escucha en :8000.
# WEBSITES_CONTAINER_START_TIME_LIMIT=600 da margen para `alembic upgrade head`.
# Ambos se definen como App Settings en Azure, no aquí.
